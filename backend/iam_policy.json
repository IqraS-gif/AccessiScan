{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AccessiScanS3Access",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::accessiscan-reports",
                "arn:aws:s3:::accessiscan-reports/*"
            ]
        },
        {
            "Sid": "AccessiScanDynamoDBAccess",
            "Effect": "Allow",
            "Action": [
                "dynamodb:PutItem",
                "dynamodb:GetItem",
                "dynamodb:UpdateItem",
                "dynamodb:Query",
                "dynamodb:Scan"
            ],
            "Resource": [
                "arn:aws:dynamodb:*:*:table/AccessiScanResults"
            ]
        },
        {
            "Sid": "AccessiScanAdvancedServicesAccess",
            "Effect": "Allow",
            "Action": [
                "sns:Publish",
                "polly:SynthesizeSpeech",
                "polly:DescribeVoices",
                "cloudwatch:PutMetricData"
            ],
            "Resource": "*"
        },
        {
            "Sid": "AccessiScanCognitoAccess",
            "Effect": "Allow",
            "Action": [
                "cognito-idp:GetUser",
                "cognito-idp:AdminGetUser",
                "cognito-idp:ListUsers"
            ],
            "Resource": [
                "arn:aws:cognito-idp:us-east-1:*:userpool/us-east-1_qPTDgvkKe"
            ]
        }
    ]
}
